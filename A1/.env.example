# Sabi Core — A1 environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# OpenAI API key. Required for both screening and embedding.
OPENAI_API_KEY=

# Optional: override the default screening model.
# Default: gpt-4o-mini
A1_SCREENER_MODEL=

# Optional: override the default embedding model.
# Default: text-embedding-3-small
A1_EMBEDDING_MODEL=
