# Sabi Core — B2 environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL connection string.
# Local development example:
#   postgresql://postgres:postgres@localhost:5432/sabi_core?schema=public
# For production, use a pooled connection URL (Neon, Supabase, RDS proxy, etc.).
DATABASE_URL=

# OpenAI API key. Required by /api/screen for LLM screening and embeddings.
OPENAI_API_KEY=

# Optional: HTTP port for local development. Defaults to 3001.
PORT=3001

# Optional: identify your application to OpenAlex (recommended).
# See https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_MAILTO=

# Optional: NCBI E-utilities identification.
# Providing an api_key and email allows higher PubMed request rates.
PUBMED_API_KEY=
PUBMED_EMAIL=
